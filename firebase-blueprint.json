{
  "entities": {
    "Activity": {
      "title": "Activity",
      "description": "An activity or outreach event organized by the youth chorus",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["id", "title", "date", "location", "description"]
    },
    "ItineraryItem": {
      "title": "ItineraryItem",
      "description": "An event itinerary item, scheduled chronologically",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "event": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "host": { "type": "string" },
        "status": { "type": "string" },
        "notes": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string" }
      },
      "required": ["id", "event", "date", "location"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A user-submitted contact or booking inquiry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "email", "message", "date", "status"]
    },
    "Leader": {
      "title": "Leader",
      "description": "A youth chorus leader or music director",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "image": { "type": "string" },
        "bio": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["id", "name", "role", "image"]
    },
    "MusicData": {
      "title": "MusicData",
      "description": "Music streaming panel details",
      "type": "object",
      "properties": {
        "songTitle": { "type": "string" },
        "artistName": { "type": "string" },
        "albumName": { "type": "string" },
        "audioUrl": { "type": "string" },
        "coverUrl": { "type": "string" },
        "quoteText": { "type": "string" },
        "label": { "type": "string" }
      },
      "required": ["songTitle", "artistName", "albumName"]
    },
    "AdminConfig": {
      "title": "AdminConfig",
      "description": "Global administration settings including passcode",
      "type": "object",
      "properties": {
        "passcode": { "type": "string" }
      },
      "required": ["passcode"]
    },
    "User": {
      "title": "User",
      "description": "A portal or app user login profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "voicePart": { "type": "string" },
        "providerId": { "type": "string" },
        "createdAt": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["uid", "email", "password"]
    },
    "UserSession": {
      "title": "UserSession",
      "description": "A temporary secure server-side session for admins and leaders",
      "type": "object",
      "properties": {
        "token": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" },
        "expiresAt": { "type": "number" }
      },
      "required": ["token", "expiresAt"]
    },
    "Subscriber": {
      "title": "Subscriber",
      "description": "A newsletter alert subscriber",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "Broadcast": {
      "title": "Broadcast",
      "description": "A sent or dispatched newsletter message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "category": { "type": "string" },
        "sentAt": { "type": "string" }
      },
      "required": ["id", "subject", "body"]
    },
    "MemberSpotlight": {
      "title": "MemberSpotlight",
      "description": "Featured member of the choir spotlight profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "image": { "type": "string" },
        "voicePart": { "type": "string" },
        "joinedYear": { "type": "string" }
      },
      "required": ["id", "name", "role", "bio"]
    }
  },
  "firestore": {
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Outreach and events calendar items"
    },
    "/itinerary/{itineraryId}": {
      "schema": "ItineraryItem",
      "description": "Performance and rehearsals itinerary events"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Submitted contact/booking inquiry messages"
    },
    "/leaders/{leaderId}": {
      "schema": "Leader",
      "description": "Choral leadership committee members"
    },
    "/configs/admin": {
      "schema": "AdminConfig",
      "description": "SDA admin passcode config"
    },
    "/configs/music": {
      "schema": "MusicData",
      "description": "Music streaming and audio meta details"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Portal user registration sessions"
    },
    "/subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Newsletter subscribers database"
    },
    "/broadcasts/{broadcastId}": {
      "schema": "Broadcast",
      "description": "Newsletter broadcast history log"
    },
    "/memberSpotlights/{spotlightId}": {
      "schema": "MemberSpotlight",
      "description": "Choir member spotlight listings"
    },
    "/sessions/{sessionId}": {
      "schema": "UserSession",
      "description": "Admin and leadership secure sessions"
    }
  }
}
